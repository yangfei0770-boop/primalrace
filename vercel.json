{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/news/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/news", "destination": "/news/index.html" },
    { "source": "/news/", "destination": "/news/index.html" }
  ]
}
